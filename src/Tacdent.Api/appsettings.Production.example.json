{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Formatting.Compact", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/tacdent-.log",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 52428800,
          "retainedFileCountLimit": 31,
          "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "RequestLogging": {
    "Enabled": true,
    "MaxBodyBytes": 4096,
    "LoggableContentTypes": [ "application/json" ],
    "BodyExcludedPaths": [ "/api/auth", "/api/appointments" ],
    "LogSuccessResponseBody": false,
    "SensitiveJsonFields": [
      "password",
      "currentPassword",
      "newPassword",
      "phone",
      "email",
      "patientName",
      "recaptchaToken",
      "token"
    ],
    "MaxCorrelationIdLength": 64
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=<host-verdigi-sunucu>;Database=<db-adi>;User Id=<db-user>;Password=<db-sifre>;TrustServerCertificate=True;Encrypt=True"
  },
  "Cors": {
    "Origins": [
      "https://<frontend-production-domaini>",
      "https://www.<frontend-production-domaini>"
    ]
  },
  "Auth": {
    "AdminEmail": "admin@<domain>",
    "AdminPassword": "<guclu-sifre>"
  },
  "Jwt": {
    "Issuer": "Tacdent",
    "Audience": "Tacdent",
    "Key": "<32+ karakter rastgele anahtar>",
    "ExpiryMinutes": 480
  },
  "Recaptcha": {
    "SecretKey": "<recaptcha-v3-secret>",
    "MinScore": 0.5,
    "Enabled": true
  },
  "InternalApi": {
    "Key": "<frontend INTERNAL_API_KEY ile ayni deger>"
  },
  "ForwardedHeaders": {
    "KnownProxies": ["127.0.0.1", "::1"]
  }
}
